lo='Animates the opacity of an element. Use this preset for entrance / exit animations or emphasis effects.\n\nProperties:\n- type: "Fade In" animates 0\u21921, "Fade Out" animates 1\u21920, "Custom" lets you specify start and end opacity via Start Frame / End Frame.\n- startFrame / endFrame: Start and end opacity as percentages (only used when type is "Custom").\n- delay: How long to wait before the animation starts, in seconds.\n- duration: The length of the animation, in seconds.\n- easing: The easing curve that controls the acceleration of the animation.',la=[{name:"type",type:s2.J0O.TEXT,label:"motion.preset_flyout.type",defaultText:"fadeIn",selectConfig:{options:[{value:"fadeIn",label:"motion.preset_flyout.opacity.type.fade_in"},{value:"fadeOut",label:"motion.preset_flyout.opacity.type.fade_out"},{value:"custom",label:"motion.preset_flyout.type.custom"}]}},{name:"amount",type:s2.J0O.NUMBER,label:"motion.preset_flyout.amount",defaultNumber:0,inputConfig:{unit:"%",icon:"opacity"}},{name:"startFrame",type:s2.J0O.NUMBER,label:"motion.preset_flyout.start",defaultNumber:0,inputConfig:{unit:"%",icon:"opacity"}},{name:"endFrame",type:s2.J0O.NUMBER,label:"motion.preset_flyout.end",defaultNumber:100,inputConfig:{unit:"%",icon:"opacity"}},{name:"delay",type:s2.J0O.NUMBER,label:"motion.preset_flyout.delay",defaultNumber:0,inputConfig:{unit:"s",icon:"delay"},numberResolvedAsTiming:!0},{name:"duration",type:s2.J0O.NUMBER,label:"motion.preset_flyout.duration",defaultNumber:.5,inputConfig:{min:.01,unit:"s",icon:"time"},numberResolvedAsTiming:!0},{name:"easing",type:s2.J0O.EASING,label:"motion.preset_flyout.easing",defaultEasing:{easingType:s2.mgy.OUT_CUBIC}}],ls="Path Draw",ll='Animates the path trim of a stroke to draw it in or erase it over time. Use this preset for line drawing effects, signature animations, or progressive reveal of vector paths.\n\nProperties:\n- duration: The length of the animation in seconds.\n- direction: Select "Forward" to draw from the start of the path to the end, or "Reverse" to draw from the end of the path to the start.',lu=[{name:"duration",type:s2.J0O.NUMBER,label:"Duration",defaultNumber:.5,inputConfig:{min:.01,unit:"s"},numberResolvedAsTiming:!0},{name:"mode",type:s2.J0O.TEXT,label:"Mode",defaultText:"reveal",selectConfig:{options:[{value:"reveal",label:"Reveal"},{value:"hide",label:"Hide"}]}},{name:"direction",type:s2.J0O.TEXT,label:"Direction",defaultText:"forward",selectConfig:{options:[{value:"forward",label:"Forward"},{value:"reverse",label:"Reverse"}]}}],ld="motion.preset_name.path",lc='Animates the trim of a vector path. Replaces and subsumes Path Draw and Path Travel under a single preset; pick a `type` to drive the behaviour.\n\nProperties:\n- type: "Draw" reveals the path from start to end; "Erase" hides it; "Travel" runs a short segment along the path; "Custom" exposes raw `pathTrimStart` / `pathTrimEnd` control via the `axis` prop.\n- direction: "Forward" or "Reverse"; reverses the animation direction.\n- segment: For type=travel, length of the moving segment as a percentage of the path.\n- axis: For type=custom, picks which trim field(s) to animate. "Path trim start" and "Path trim end" each drive one field. "Combined" drives both with shared timing but distinct initial values (`pathStartStartFrame`, `pathEndStartWithDivider`).\n- pathStart{StartFrame,EndFrame} / pathEnd{StartFrame,EndFrame}: For type=custom, the per-trim frame values. The bespoke component shows only the subset relevant to the current axis selection.\n- delay / duration / easing: Shared timing for every type (Draw / Erase / Travel and Custom).',lp=[{name:"type",type:s2.J0O.TEXT,label:"motion.preset_flyout.type",defaultText:"draw",selectConfig:{options:[{value:"draw",label:"motion.preset_flyout.path.type.draw"},{value:"erase",label:"motion.preset_flyout.path.type.erase"},{value:"travel",label:"motion.preset_flyout.path.type.travel"},{value:"custom",label:"motion.preset_flyout.type.custom"}]}},{name:"direction",type:s2.J0O.TEXT,label:"motion.preset_flyout.direction",defaultText:"forward",selectConfig:{options:[{value:"forward",label:"motion.preset_flyout.path.direction.forward"},{value:"reverse",label:"motion.preset_flyout.path.direction.reverse"}]}},{name:"axis",type:s2.J0O.TEXT,label:"motion.preset_flyout.path.trim",defaultText:"pathTrimStart",selectConfig:{options:[{value:"pathTrimStart",label:"motion.preset_flyout.path.axis.path_trim_start"},{value:"pathTrimEnd",label:"motion.preset_flyout.path.axis.path_trim_end"},{value:"combined",label:"motion.preset_flyout.path.axis.combined"}]}},{name:"segment",type:s2.J0O.NUMBER,label:"motion.preset_flyout.path.segment",defaultNumber:10,inputConfig:{unit:"%"}},{name:"pathStartStartFrame",type:s2.J0O.NUMBER,label:"motion.preset_flyout.start_frame",defaultNumber:100,inputConfig:{unit:"%",icon:"path_trim_start"}},{name:"pathStartEndWithoutDivider",type:s2.J0O.NUMBER,label:"motion.preset_flyout.end_frame",defaultNumber:0,inputConfig:{unit:"%",icon:"path_trim_start"}},{name:"pathEndStartWithoutDivider",type:s2.J0O.NUMBER,label:"motion.preset_flyout.start_frame",defaultNumber:20,inputConfig:{unit:"%",icon:"path_trim_end"}},{name:"pathStartEndWithDivider",type:s2.J0O.NUMBER,label:"motion.preset_flyout.end_frame",defaultNumber:80,inputConfig:{unit:"%",icon:"path_trim_start"}},{name:"pathEndStartWithDivider",type:s2.J0O.NUMBER,label:"motion.preset_flyout.start_frame",defaultNumber:0,inputConfig:{unit:"%",icon:"path_trim_end"}},{name:"pathEndEndFrame",type:s2.J0O.NUMBER,label:"motion.preset_flyout.end_frame",defaultNumber:100,inputConfig:{unit:"%",icon:"path_trim_end"}},{name:"delay",type:s2.J0O.NUMBER,label:"motion.preset_flyout.delay",defaultNumber:0,inputConfig:{unit:"s",icon:"delay"},numberResolvedAsTiming:!0},{name:"duration",type:s2.J0O.NUMBER,label:"motion.preset_flyout.duration",defaultNumber:.5,inputConfig:{min:.01,unit:"s",icon:"time"},numberResolvedAsTiming:!0},{name:"easing",type:s2.J0O.EASING,label:"motion.preset_flyout.easing",defaultEasing:{easingType:s2.mgy.OUT_CUBIC}}],lf="Path Travel",lh='Animates a segment of a stroke that travels along the entire path. Use this preset for moving highlight effects or traveling dash animations on vector paths.\n\nProperties:\n- segmentLength: The length of the traveling segment as a percentage of the total path.\n- loops: The number of times the segment travels along the path.\n- loopMode: Select "Circle Back" to wrap continuously around the path, or "Retrace Path" to bounce forward then backward each loop.\n- direction: Select "Forward" to travel from the start to the end of the path, or "Reverse" to travel from the end to the start.\n- duration: The length of the animation in seconds.',lm=[{name:"duration",type:s2.J0O.NUMBER,label:"Duration",defaultNumber:.5,inputConfig:{min:.01,unit:"s"},numberResolvedAsTiming:!0},{name:"direction",type:s2.J0O.TEXT,label:"Direction",defaultText:"forward",selectConfig:{options:[{value:"forward",label:"Forward"},{value:"reverse",label:"Reverse"}]}},{name:"loopMode",type:s2.J0O.TEXT,label:"Loop Mode",defaultText:"circle",selectConfig:{options:[{value:"circle",label:"Circle Back"},{value:"retrace",label:"Retrace Path"}]}},{name:"segmentLength",type:s2.J0O.NUMBER,label:"Segment Length",defaultNumber:20,inputConfig:{min:0,max:100,unit:"%"}},{name:"loops",type:s2.J0O.NUMBER,label:"Loops",defaultNumber:1,inputConfig:{min:1}}],lg="motion.preset_name.position",l_='Animates a node along the X and/or Y axes. Use this preset for slide-in / slide-out entrances and exits, or fully custom translate animations.\n\nProperties:\n- type: "Slide In" animates from an offset back to the resting position, "Slide Out" animates from the resting position to an offset, "Custom" lets you specify Start / End values explicitly.\n- direction: For Slide In / Slide Out, the side the element slides from / to (only used when type is "Slide In" or "Slide Out").\n- distance: Slide distance in pixels (only used when type is "Slide In" or "Slide Out").\n- axis: For Custom, which axes to animate \u2014 "X" / "Y" animate one axis only, "XY" animates both (each axis keeps its own start/end and they share the timing).\n- startX / endX: X-axis start and end translation in pixels (used when type is "Custom" and axis is "X" or "XY").\n- startY / endY: Y-axis start and end translation in pixels (used when type is "Custom" and axis is "Y" or "XY").\n- delay: How long to wait before the animation starts, in seconds.\n- duration: The length of a single playthrough, in seconds.\n- easing: The easing curve that controls the acceleration of the animation.',lE=[{name:"type",type:s2.J0O.TEXT,label:"motion.preset_flyout.type",defaultText:"slide_in",selectConfig:{options:[{value:"slide_in",label:"motion.preset_flyout.position.type.slide_in"},{value:"slide_out",label:"motion.preset_flyout.position.type.slide_out"},{value:"custom",label:"motion.preset_flyout.type.custom"}]}},{name:"direction",type:s2.J0O.TEXT,label:"motion.preset_flyout.direction",defaultText:"left",selectConfig:{options:[{value:"left",label:"motion.preset_flyout.position.direction.left"},{value:"right",label:"motion.preset_flyout.position.direction.right"},{value:"top",label:"motion.preset_flyout.position.direction.top"},{value:"bottom",label:"motion.preset_flyout.position.direction.bottom"},{value:"top_left",label:"motion.preset_flyout.top_left"},{value:"top_right",label:"motion.preset_flyout.top_right"},{value:"bottom_left",label:"motion.preset_flyout.bottom_left"},{value:"bottom_right",label:"motion.preset_flyout.bottom_right"}]}},{name:"distance",type:s2.J0O.NUMBER,label:"motion.preset_flyout.position.distance",defaultNumber:200,inputConfig:{unit:"px"}},{name:"axis",type:s2.J0O.TEXT,label:"motion.preset_flyout.axis",defaultText:"xy",selectConfig:{options:[{value:"x",label:"motion.preset_flyout.x"},{value:"y",label:"motion.preset_flyout.y"},{value:"xy",label:"motion.preset_flyout.both"}]}},{name:"startX",type:s2.J0O.NUMBER,label:"motion.preset_flyout.start",defaultNumber:200,inputConfig:{icon:"x"}},{name:"startY",type:s2.J0O.NUMBER,label:"motion.preset_flyout.start",defaultNumber:200,inputConfig:{icon:"y"}},{name:"endX",type:s2.J0O.NUMBER,label:"motion.preset_flyout.end",defaultNumber:0,inputConfig:{icon:"x"}},{name:"endY",type:s2.J0O.NUMBER,label:"motion.preset_flyout.end",defaultNumber:0,inputConfig:{icon:"y"}},{name:"delay",type:s2.J0O.NUMBER,label:"motion.preset_flyout.delay",defaultNumber:0,inputConfig:{unit:"s",icon:"delay"},numberResolvedAsTiming:!0},{name:"duration",type:s2.J0O.NUMBER,label:"motion.preset_flyout.duration",defaultNumber:.5,inputConfig:{min:.01,unit:"s",icon:"time"},numberResolvedAsTiming:!0},{name:"easing",type:s2.J0O.EASING,label:"motion.preset_flyout.easing",defaultEasing:{easingType:s2.mgy.OUT_CUBIC}}],lT="Changes the width and/or height of an element by a pixel offset over time. Use this preset for expanding panels, progress bar animations, or dynamic layout transitions.\n\nProperties:\n- widthChange: The amount to change the element's width in pixels (0 for no width change).\n- heightChange: The amount to change the element's height in pixels (0 for no height change).\n- duration: The length of the animation in seconds.\n- easing: The easing curve that controls the acceleration of the resize.",ly=[{name:"widthChange",type:s2.J0O.NUMBER,label:"Width Change",defaultNumber:100},{name:"heightChange",type:s2.J0O.NUMBER,label:"Height Change",defaultNumber:0},{name:"duration",type:s2.J0O.NUMBER,label:"Duration",defaultNumber:.5,inputConfig:{min:.01,unit:"s"},numberResolvedAsTiming:!0},{name:"easing",type:s2.J0O.EASING,label:"Easing",defaultEasing:{easingType:s2.mgy.OUT_CUBIC}}],lS='Rotates an element by a specified angle to spin it in or out. Use this preset for spinning entrance or exit effects, turning animations, or attention-grabbing rotations.\n\nProperties:\n- timing: Select "Rotate In" to rotate from the specified angle back to the original orientation, or "Rotate Out" to rotate from the original orientation to the specified angle.\n- rotation: The rotation amount in degrees.\n- duration: The length of the animation in seconds.\n- fade: Enable to simultaneously fade the element\'s opacity during the rotation.\n- easing: The easing curve that controls the acceleration of the rotation.',lI=[{name:"timing",type:s2.J0O.TEXT,label:"Timing",defaultText:"out",selectConfig:{options:[{value:"in",label:"In"},{value:"out",label:"Out"}]}},{name:"rotation",type:s2.J0O.NUMBER,label:"Rotation",defaultNumber:180},{name:"duration",type:s2.J0O.NUMBER,label:"Duration",defaultNumber:.5,inputConfig:{min:.01,unit:"s"},numberResolvedAsTiming:!0},{name:"fade",type:s2.J0O.BOOL,label:"Fade",defaultBool:!1},{name:"easing",type:s2.J0O.EASING,label:"Easing",defaultEasing:{easingType:s2.mgy.OUT_CUBIC}}],lb="motion.preset_name.rotation",lv='Animates the rotation of a node about its center. Use this preset for spin-in / spin-out reveal effects, or pick the Custom type for explicit start / end angles.\n\nProperties:\n- type: "Rotate in" animates signed amount \u2192 0; "Rotate out" animates 0 \u2192 signed amount; "Custom" lets you specify explicit start / end angles in degrees. The signed amount is derived from Direction (see below).\n- direction: "Clockwise" or "Counter-clockwise". Underlying `rotate` is in radians and uses screen Y-down coordinates. For "Rotate in", Clockwise yields a negative angle and Counter-clockwise yields a positive angle. For "Rotate out", Clockwise yields a positive angle and Counter-clockwise yields a negative angle \u2014 matching the visible spin labels in both types.\n- amount: For type=rotateIn/rotateOut, the rotation magnitude in degrees.\n- start / end: For type=custom, the explicit start / end angles in degrees.\n- delay / duration / easing: Shared timing for the animation.',lO=[{name:"type",type:s2.J0O.TEXT,label:"motion.preset_flyout.type",defaultText:"rotateIn",selectConfig:{options:[{value:"rotateIn",label:"motion.preset_flyout.rotation.type.rotate_in"},{value:"rotateOut",label:"motion.preset_flyout.rotation.type.rotate_out"},{value:"custom",label:"motion.preset_flyout.type.custom"}]}},{name:"direction",type:s2.J0O.TEXT,label:"motion.preset_flyout.direction",defaultText:"clockwise",selectConfig:{options:[{value:"clockwise",label:"motion.preset_flyout.rotation.direction.clockwise"},{value:"counterClockwise",label:"motion.preset_flyout.rotation.direction.counter_clockwise"}]}},{name:"amount",type:s2.J0O.NUMBER,label:"motion.preset_flyout.amount",defaultNumber:180,inputConfig:{unit:"\xb0"}},{name:"start",type:s2.J0O.NUMBER,label:"motion.preset_flyout.start",defaultNumber:180,inputConfig:{unit:"\xb0",icon:"rotation"}},{name:"end",type:s2.J0O.NUMBER,label:"motion.preset_flyout.end",defaultNumber:0,inputConfig:{unit:"\xb0",icon:"rotation"}},{name:"delay",type:s2.J0O.NUMBER,label:"motion.preset_flyout.delay",defaultNumber:0,inputConfig:{min:0,unit:"s",icon:"delay"},numberResolvedAsTiming:!0},{name:"duration",type:s2.J0O.NUMBER,label:"motion.preset_flyout.duration",defaultNumber:.5,inputConfig:{min:.01,unit:"s",icon:"time"},numberResolvedAsTiming:!0},{name:"easing",type:s2.J0O.EASING,label:"motion.preset_flyout.easing",defaultEasing:{easingType:s2.mgy.OUT_CUBIC}}],lA="motion.preset_name.scale",lR='Animates a node by scaling it along the width and/or height axis. Use this preset for scale-in / scale-out reveal effects, or pick the Custom type for explicit start / end percentages on either axis.\n\nProperties:\n- type: "Scale in" animates amount \u2192 100%; "Scale out" animates 100% \u2192 amount; "Custom" lets you specify explicit start / end percentages per axis.\n- axis: For type=custom, picks which axis (W, H, or both combined) is animated. Ignored when type=scaleIn/scaleOut (both axes animate together).\n- amount: For type=scaleIn/scaleOut, the scale magnitude in percent (e.g. 120%).\n- {w,h}{Start,End}* / *WithDivider / *WithoutDivider: For type=custom, the explicit start / end percentages per axis. Single-axis groups each axis as Start+End; WH-combined groups both Starts together and both Ends together, using the alternate divider variants. Only the set visible in the current layout is editable.\n- delay / duration / easing: Shared timing.',lC=[{name:"type",type:s2.J0O.TEXT,label:"motion.preset_flyout.type",defaultText:"scaleIn",selectConfig:{options:[{value:"scaleIn",label:"motion.preset_flyout.scale.type.scale_in"},{value:"scaleOut",label:"motion.preset_flyout.scale.type.scale_out"},{value:"custom",label:"motion.preset_flyout.type.custom"}]}},{name:"axis",type:s2.J0O.TEXT,label:"motion.preset_flyout.axis",defaultText:"whCombined",selectConfig:{options:[{value:"w",label:"motion.preset_flyout.w"},{value:"h",label:"motion.preset_flyout.h"},{value:"whCombined",label:"motion.preset_flyout.both"}]}},{name:"amount",type:s2.J0O.NUMBER,label:"motion.preset_flyout.amount",defaultNumber:120,inputConfig:{min:0,unit:"%"}},{name:"wStartWithDivider",type:s2.J0O.NUMBER,label:"motion.preset_flyout.start",defaultNumber:120,inputConfig:{min:0,unit:"%",icon:"w"}},{name:"wEndWithoutDivider",type:s2.J0O.NUMBER,label:"motion.preset_flyout.end",defaultNumber:100,inputConfig:{min:0,unit:"%",icon:"w"}},{name:"hStartWithoutDivider",type:s2.J0O.NUMBER,label:"motion.preset_flyout.start",defaultNumber:120,inputConfig:{min:0,unit:"%",icon:"h"}},{name:"wEndWithDivider",type:s2.J0O.NUMBER,label:"motion.preset_flyout.end",defaultNumber:100,inputConfig:{min:0,unit:"%",icon:"w"}},{name:"hStartWithDivider",type:s2.J0O.NUMBER,label:"motion.preset_flyout.start",defaultNumber:120,inputConfig:{min:0,unit:"%",icon:"h"}},{name:"hEndWithoutDivider",type:s2.J0O.NUMBER,label:"motion.preset_flyout.end",defaultNumber:100,inputConfig:{min:0,unit:"%",icon:"h"}},{name:"delay",type:s2.J0O.NUMBER,label:"motion.preset_flyout.delay",defaultNumber:0,inputConfig:{unit:"s",icon:"delay"},numberResolvedAsTiming:!0},{name:"duration",type:s2.J0O.NUMBER,label:"motion.preset_flyout.duration",defaultNumber:.5,inputConfig:{min:.01,unit:"s",icon:"time"},numberResolvedAsTiming:!0},{name:"easing",type:s2.J0O.EASING,label:"motion.preset_flyout.easing",defaultEasing:{easingType:s2.mgy.OUT_CUBIC}}],lN="motion.preset_name.size",lD='Animates a node\u2019s width and/or height. Use this preset for resize-in / resize-out entrances and exits, or fully custom resize animations.\n\nProperties:\n- type: "Resize In" starts at the resting size and shrinks by `amount`, "Resize Out" starts shrunk by `amount` and grows back to the resting size, "Custom" lets you specify Start / End values explicitly.\n- amount: How many pixels to shrink the width AND height by (only used when type is "Resize In" or "Resize Out").\n- axis: For Custom, which axes to animate \u2014 "X" / "Y" animate one axis only, "Both" animates both (each axis keeps its own start/end and they share the timing).\n- startWidth / endWidth: Width start and end offset in pixels relative to the resting size (used when type is "Custom" and axis is "X" or "Both").\n- startHeight / endHeight: Height start and end offset in pixels relative to the resting size (used when type is "Custom" and axis is "Y" or "Both").\n- delay: How long to wait before the animation starts, in seconds.\n- duration: The length of a single playthrough, in seconds.\n- easing: The easing curve that controls the acceleration of the animation.',lw=[{name:"type",type:s2.J0O.TEXT,label:"motion.preset_flyout.type",defaultText:"resize_in",selectConfig:{options:[{value:"resize_in",label:"motion.preset_flyout.size.type.resize_in"},{value:"resize_out",label:"motion.preset_flyout.size.type.resize_out"},{value:"custom",label:"motion.preset_flyout.type.custom"}]}},{name:"amount",type:s2.J0O.NUMBER,label:"motion.preset_flyout.amount",defaultNumber:50,inputConfig:{unit:"px"}},{name:"axis",type:s2.J0O.TEXT,label:"motion.preset_flyout.axis",defaultText:"xy",selectConfig:{options:[{value:"x",label:"motion.preset_flyout.x"},{value:"y",label:"motion.preset_flyout.y"},{value:"xy",label:"motion.preset_flyout.both"}]}},{name:"startWidth",type:s2.J0O.NUMBER,label:"motion.preset_flyout.start",defaultNumber:50,inputConfig:{icon:"w"}},{name:"startHeight",type:s2.J0O.NUMBER,label:"motion.preset_flyout.start",defaultNumber:50,inputConfig:{icon:"h"}},{name:"endWidth",type:s2.J0O.NUMBER,label:"motion.preset_flyout.end",defaultNumber:100,inputConfig:{icon:"w"}},{name:"endHeight",type:s2.J0O.NUMBER,label:"motion.preset_flyout.end",defaultNumber:100,inputConfig:{icon:"h"}},{name:"delay",type:s2.J0O.NUMBER,label:"motion.preset_flyout.delay",defaultNumber:0,inputConfig:{unit:"s",icon:"delay"},numberResolvedAsTiming:!0},{name:"duration",type:s2.J0O.NUMBER,label:"motion.preset_flyout.duration",defaultNumber:.5,inputConfig:{min:.01,unit:"s",icon:"time"},numberResolvedAsTiming:!0},{name:"easing",type:s2.J0O.EASING,label:"motion.preset_flyout.easing",defaultEasing:{easingType:s2.mgy.OUT_CUBIC}}],lL="motion.preset_name.text",lP='Animates the text content of an element by keyframing textData with string values. Use this preset for typewriter effects that reveal text by character, word, or line.\n\nProperties:\n- revealBy: Select "Character", "Word", or "Line" to control how much text appears at each keyframe.\n- duration: The length of the animation in seconds.',lx=[{name:"revealBy",type:s2.J0O.TEXT,label:"Reveal By",defaultText:"character",selectConfig:{options:[{value:"character",label:"Character"},{value:"word",label:"Word"},{value:"line",label:"Line"}]}},{name:"duration",type:s2.J0O.NUMBER,label:"Duration",defaultNumber:1.5,inputConfig:{min:.01,unit:"s"},numberResolvedAsTiming:!0}],lk={[s2.Ewp.FADE_DEPRECATED]:{name:"Fade",description:s4,propDefs:s5,manifest:{icon:"Fade",applicableNodeTypes:[],disallowedNodeTypes:[],requiredNodeFields:[],disallowedNodeFields:[]}},[s2.Ewp.MOVE_DEPRECATED]:{name:"Move",description:s6,propDefs:s8,manifest:{icon:"Move",applicableNodeTypes:[],disallowedNodeTypes:[],requiredNodeFields:[],disallowedNodeFields:[]}},[s2.Ewp.ROTATE_DEPRECATED]:{name:"Rotate",description